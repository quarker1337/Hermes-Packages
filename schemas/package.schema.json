{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hermes package manifest",
  "type": "object",
  "required": ["schema_version", "name", "display_name", "version", "type", "channel", "description", "install", "permissions"],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "name": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "display_name": {"type": "string"},
    "version": {"type": "string"},
    "type": {"enum": ["toolset", "skill", "mcp", "provider", "bundle", "plugin"]},
    "channel": {"enum": ["official", "skills", "mcp", "community"]},
    "description": {"type": "string"},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "install": {"type": "object"},
    "tools": {"type": "object"},
    "permissions": {"type": "object"},
    "env": {"type": "object"},
    "checks": {"type": "object"},
    "security": {"type": "object"}
  }
}
